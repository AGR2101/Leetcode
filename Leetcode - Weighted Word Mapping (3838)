from typing import List

class Solution:
    def mapWordWeights(self, words: List[str], weights: List[int]) -> str:
        
        result_chars = []
        
        for word in words:
            
            weight_sum = sum(weights[ord(ch) - ord('a')] for ch in word)
            
           
            mod_val = weight_sum % 26
            
            mapped_char = chr(ord('z') - mod_val)
            
            result_chars.append(mapped_char)
        
        return ''.join(result_chars)
