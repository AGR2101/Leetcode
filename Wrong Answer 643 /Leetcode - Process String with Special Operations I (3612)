class Solution(object):
    def processStr(self, s):
        """
        :type s: str
        :rtype: str
        """

        if s is None :
            return None

        result = []

        for char in s:

            if char.islower():
                result.append(char)

            elif char == "*":
                if result:
                    result.pop()

            elif char == "#":
                if result :
                    result.extend(result)

            elif char == "%":
                result.reverse()

            else :
                result.append(char)

        return ''.join(result) if result else ""


            
        
