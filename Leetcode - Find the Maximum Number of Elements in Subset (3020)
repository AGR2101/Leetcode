class Solution(object):
    def maximumLength(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        freq = Counter(nums)
        ans = 1
        
        if 1 in freq:
            ans = max(ans, freq[1] if freq[1] % 2 == 1 else freq[1] - 1)
        
        for x in freq:
            if x == 1:
                continue
                
            chain = []
            curr = x
            while curr in freq and curr <= 10**9:
                chain.append(curr)
                curr = curr * curr
            
            for i in range(len(chain)):
                can_use = True
                for j in range(i):
                    if freq[chain[j]] < 2:
                        can_use = False
                        break
                
                if can_use:
                    ans = max(ans, 2 * i + 1)
        
        return ans
        
