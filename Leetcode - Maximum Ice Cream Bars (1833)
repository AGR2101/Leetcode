class Solution(object):
    def maxIceCream(self, costs, coins):
        """
        :type costs: List[int]
        :type coins: int
        :rtype: int
        """
        max_price = max(costs)
        count = [0] * (max_price + 1)
        
        for cost in costs:
            count[cost] += 1
        
        ans = 0
        
        for price in range(1, max_price + 1):
            if count[price] == 0:
                continue
            
            can_buy = min(count[price], coins // price)
            ans += can_buy
            coins -= can_buy * price
            
            if coins < price:
                break
        
        return ans
