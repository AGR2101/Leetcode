class Solution(object):
    def maxBuilding(self, n, restrictions):
        """
        :type n: int
        :type restrictions: List[List[int]]
        :rtype: int
        """
        restrictions.append([1, 0])
        restrictions.sort()
        
        if restrictions[-1][0] != n:
            restrictions.append([n, float('inf')])
        
        for i in range(1, len(restrictions)):
            prev_idx, prev_height = restrictions[i-1]
            curr_idx, curr_height = restrictions[i]
            max_possible = prev_height + (curr_idx - prev_idx)
            if curr_height > max_possible:
                restrictions[i] = [curr_idx, max_possible]
        
        for i in range(len(restrictions) - 2, -1, -1):
            curr_idx, curr_height = restrictions[i]
            next_idx, next_height = restrictions[i+1]
            max_possible = next_height + (next_idx - curr_idx)
            if curr_height > max_possible:
                restrictions[i] = [curr_idx, max_possible]
        
        ans = 0
        
        for i in range(len(restrictions) - 1):
            idx1, h1 = restrictions[i]
            idx2, h2 = restrictions[i+1]
            distance = idx2 - idx1
            max_height_in_segment = (h1 + h2 + distance) // 2
            ans = max(ans, max_height_in_segment)
        
        return ans
